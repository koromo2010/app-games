# Copy this file to .env.word-db.local before starting the local database.
# .env.word-db.local is ignored by Git.
WORD_DB_PORT=5432
WORD_DB_NAME=app_games
WORD_DB_USER=app_games
WORD_DB_PASSWORD=replace-with-a-local-only-password
DATABASE_URL=postgresql://app_games:replace-with-a-local-only-password@127.0.0.1:5432/app_games
