{
  "name": "@game-fields/game-runtime",
  "version": "0.1.0",
  "description": "Private Game Fields adapter for authenticated, revisioned game rooms.",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@game-fields/game-sdk": "0.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
