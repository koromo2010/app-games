{
  "name": "@game-fields/game-sdk",
  "version": "0.1.0",
  "description": "Public contracts, reusable game resources, and mock/runtime helpers for Game Fields.",
  "keywords": [
    "game-fields",
    "game-sdk",
    "multiplayer",
    "cards",
    "drawing"
  ],
  "homepage": "https://sdk.game-fields.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/koromo2010/app-games.git",
    "directory": "packages/game-sdk"
  },
  "bugs": {
    "url": "https://github.com/koromo2010/app-games/issues"
  },
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js",
      "default": "./dist/runtime.js"
    },
    "./modules": {
      "types": "./dist/modules.d.ts",
      "import": "./dist/modules.js",
      "default": "./dist/modules.js"
    },
    "./content-source": {
      "types": "./dist/content-source.d.ts",
      "import": "./dist/content-source.js",
      "default": "./dist/content-source.js"
    },
    "./llm": {
      "types": "./dist/llm.d.ts",
      "import": "./dist/llm.js",
      "default": "./dist/llm.js"
    },
    "./resources": {
      "types": "./dist/resources.d.ts",
      "import": "./dist/resources.js",
      "default": "./dist/resources.js"
    },
    "./playing-cards": {
      "types": "./dist/playing-cards.d.ts",
      "import": "./dist/playing-cards.js",
      "default": "./dist/playing-cards.js"
    },
    "./playing-cards-react": {
      "types": "./dist/playing-cards-react.d.ts",
      "import": "./dist/playing-cards-react.js",
      "default": "./dist/playing-cards-react.js"
    },
    "./drawing": {
      "types": "./dist/drawing.d.ts",
      "import": "./dist/drawing.js",
      "default": "./dist/drawing.js"
    },
    "./drawing-react": {
      "types": "./dist/drawing-react.d.ts",
      "import": "./dist/drawing-react.js",
      "default": "./dist/drawing-react.js"
    },
    "./mock-runtime": {
      "types": "./dist/mock-runtime.d.ts",
      "import": "./dist/mock-runtime.js",
      "default": "./dist/mock-runtime.js"
    },
    "./client-runtime": {
      "types": "./dist/client-runtime.d.ts",
      "import": "./dist/client-runtime.js",
      "default": "./dist/client-runtime.js"
    },
    "./handshake": {
      "types": "./dist/handshake.d.ts",
      "import": "./dist/handshake.js",
      "default": "./dist/handshake.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "prepack": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18.2.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=20"
  }
}
