{
  "name": "game-fields-my-first-game",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "description": "A game package created with the Game Fields SDK starter.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test dist/tests/*.test.js",
    "demo": "npm run build && node dist/src/demo.js",
    "check:mock": "node scripts/check-mock.mjs",
    "publish:mock": "node scripts/publish-mock.mjs",
    "diagnose:promotion": "node scripts/check-promotion-readiness.mjs",
    "build:game-package": "node scripts/build-game-package.mjs",
    "publish:game-package": "npm run build:game-package && node scripts/publish-game-package.mjs",
    "check": "npm test",
    "package": "node scripts/build-submission.mjs"
  },
  "dependencies": {
    "@game-fields/game-sdk": "file:vendor/__SDK_TARBALL__"
  },
  "devDependencies": {
    "@types/node": "^20",
    "esbuild": "^0.28.1",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=20"
  }
}
