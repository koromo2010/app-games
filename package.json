{
    "name": "app-games",
    "version": "0.1.1",
    "private": true,
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "dev": "npm run build:runtime-packages && next dev -p 3000",
        "dev:sdk": "npm run dev --workspace @game-fields/sdk-portal",
        "dev:sdk-preview": "npm run dev --workspace @game-fields/sdk-preview",
        "build": "npm run build:runtime-packages && next build",
        "build:sdk": "npm run build --workspace @game-fields/sdk-portal",
        "build:sdk-preview": "npm run build --workspace @game-fields/sdk-preview",
        "build:sdk-package": "npm run build --workspace @game-fields/game-sdk",
        "build:runtime-packages": "npm run build:sdk-package && npm run build --workspace @game-fields/game-runtime",
        "start": "next start -p 3000",
        "lint": "npm run check:versions && npm run check:env-ledger && npm run check:games && npm run check:sdk && eslint",
        "test": "npm run build:runtime-packages && node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types --test tests/*.test.ts",
        "test:sdk-package": "npm run build:sdk-package && node scripts/check-game-sdk-package.mjs",
        "release:sdk:check": "npm run test:sdk-package && npm publish --workspace @game-fields/game-sdk --dry-run",
        "build:sdk-starter": "node scripts/build-game-sdk-starter.mjs",
        "build:sdk-starter-repository": "node scripts/build-game-sdk-starter-repository.mjs",
        "test:sdk-starter": "node scripts/check-game-sdk-starter.mjs",
        "check:games": "node scripts/check-game-standards.mjs",
        "check:sdk": "node scripts/check-game-sdk-boundaries.mjs",
        "check:env-ledger": "node scripts/check-environment-ledger.mjs",
        "check:versions": "node scripts/check-platform-release.mjs",
        "create-game": "node scripts/create-game.mjs",
        "load:smoke": "node scripts/load-test.mjs",
        "monitor:production": "node scripts/production-smoke.mjs",
        "vocabulary:migrate": "node --experimental-strip-types scripts/migrate-vocabulary-to-master.ts",
        "vocabulary:import-legacy-words": "node --experimental-strip-types scripts/import-legacy-word-catalog.ts"
    },
    "dependencies": {
        "@game-fields/game-runtime": "0.1.1",
        "@game-fields/sdk-preview-auth": "0.1.1",
        "@neondatabase/serverless": "^1.1.0",
        "@simplewebauthn/browser": "^13.3.0",
        "@simplewebauthn/server": "^13.3.2",
        "@vercel/blob": "^2.6.1",
        "@vercel/functions": "^3.7.5",
        "next": "16.2.4",
        "openai": "^6.34.0",
        "react": "19.2.4",
        "react-dom": "19.2.4",
        "redis": "^5.12.1",
        "resend": "^6.17.2",
        "ws": "^8.21.1"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4",
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "@types/ws": "^8.18.1",
        "esbuild": "^0.28.1",
        "eslint": "^9",
        "eslint-config-next": "16.2.4",
        "tailwindcss": "^4",
        "typescript": "^5"
    }
}
